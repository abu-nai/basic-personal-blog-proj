<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit</title>
</head>
<body>
    <h1>Edit your post:</h1>
    <form method="POST" action="/blog/<%=blogpost.id%>?_method=PATCH">
        <label for="comment"></label>
        <textarea name="comment" cols="30" rows="10"><%= blogpost.comment %></textarea>
        <br>
        <button>save changes</button>        
    </form>
    <a href="/blog/<%=blogpost.id%>">back to post page</a>
</body>
</html>