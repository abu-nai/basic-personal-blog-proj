<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Show</title>
</head>
<body>
    <h1>Comment id: <%= comment.id %> </h1>
    <h2><%= comment.username %> - <%= comment.date %> </h2>
    <p><%= comment.comment %></p>

    <a href="/comments">Back to all posts...</a>
    <a href="/comments/<%= comment.id %>/edit">Edit post...</a>
    <form method="POST" action="/comments/<%= comment.id %>?_method=DELETE">
        <button>delete</button>
    </form>
</body>
</html>